generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String
  email     String   @unique
  avatar    String?
  posName   String?
  pitArea   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Truck {
  id               Int        @id @default(autoincrement())
  code             String     @unique
  truckNumber      String
  truckType        String
  truckTypeLabel   String
  registeredBy     String
  registeredByRole String
  registeredAt     DateTime   @default(now())
  status           String
  photo            String?
  lastUpdatedBy    String?
  lastUpdatedAt    DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  checkouts        Checkout[]

  @@index([truckNumber])
  @@index([status])
}

model Checkout {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  truckId        Int
  truckCode      String
  truckNumber    String
  truckType      String
  truckTypeLabel String
  materialType   String?
  pitOwner       String
  excaId         String
  excaOperator   String
  contractor     String?
  createdBy      String
  createdByRole  String
  createdAt      DateTime  @default(now())
  status         String
  verifiedBy     String?
  verifiedAt     DateTime?
  photo          String?
  updatedAt      DateTime  @updatedAt
  truck          Truck     @relation(fields: [truckId], references: [id], onDelete: Restrict)

  @@index([truckId])
  @@index([truckCode])
  @@index([status])
  @@index([materialType])
  @@index([contractor])
}

model ManualMigration {
  name      String   @id
  appliedAt DateTime @default(now())

  @@map("_manual_migrations")
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
